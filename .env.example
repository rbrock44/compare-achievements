# Copy this file to .env (already gitignored) and fill in your real Steam Web API key.
# Get a key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# PSN has no official public API. This authenticates the server as a single PlayStation
# account, which is then used to look up any public profile/trophy data.
# Get an npsso token by logging into PSN in your browser, then visiting
# https://ca.account.sony.com/api/v1/ssocookie and copying the "npsso" value from the response.
# It's exchanged for short-lived access/refresh tokens at runtime, so you only need to refresh
# this value again once the (long-lived) refresh token itself expires.
PSN_NPSSO=
